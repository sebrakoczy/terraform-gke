# ---- build stage ----
FROM golang:1.23 AS build
WORKDIR /src
COPY go.mod ./
# go.sum is generated by `go mod tidy`; copy if present
COPY go.su[m] ./
RUN go mod download || true
COPY . .
# Static, stripped binary so it runs on a distroless/scratch base.
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /app .

# ---- runtime stage: distroless, non-root, minimal attack surface ----
FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /
COPY --from=build /app /app
USER nonroot:nonroot
EXPOSE 8080
ENTRYPOINT ["/app"]
